{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "dist/lib",
    "rootDir": "src",
    "noEmit": false
  },
  "include": ["src/lib/**/*.ts", "src/shared/**/*.ts", "src/parser/xliff.ts"],
  "exclude": ["node_modules", "dist", "src/ui/**", "src/code.ts", "src/figma/**"]
}

